ance.on('disconnect', () => {\r\n      setIsConnected(false);\r\n    });\r\n\r\n    socketInstance.on('user_status_change', (data: { userId: string; status: 'online' | 'offline' }) => {\r\n      setOnlineUsers((prev) => {\r\n        const next = new Set(prev);\r\n        if (data.status === 'online') {\r\n          next.add(data.userId);\r\n        } else {\r\n          next.delete(data.userId);\r\n        }\r\n        return next;\r\n      });\r\n    });\r\n\r\n    return () => {\r\n      socketInstance.disconnect();\r\n      setIsConnected(false);\r\n    };\r\n    // eslint-disable-next-line react-hooks/exhaustive-deps\r\n  }, [userId]);\r\n\r\n  return { socket, isConnected, onlineUsers };\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\mailu\\Desktop\\Utter.In\\frontend\\src\\hooks\\useSubmitForm.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\mailu\\Desktop\\Utter.In\\frontend\\src\\proxy.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\mailu\\Desktop\\Utter.In\\frontend\\src\\services\\admin\\authService.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\mailu\\Desktop\\Utter.In\\frontend\\src\\services\\admin\\tutorsService.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\mailu\\Desktop\\Utter.In\\frontend\\src\\services\\admin\\usersService.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecated